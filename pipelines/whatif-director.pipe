{
  "components": [
    {
      "id": "chat_input",
      "provider": "chat",
      "config": {
        "mode": "question",
        "type": "chat"
      },
      "ui": {"position": {"x": 0, "y": 200}}
    },
    {
      "id": "director_agent",
      "provider": "agent_rocketride",
      "config": {
        "instructions": [
          "You are the DirectorAgent for the What-If football counterfactual system.",
          "The user will give you a 'what if' question about a football match. You must:",
          "1. Use the search tool to find the relevant moment in the match timeline",
          "2. Compose a structured Veo video generation brief with scene, continuity, counterfactual, and continuation beats",
          "3. Return the brief as a JSON object matching the Veo schema",
          "Always ground your response in the match events and captions provided. Never invent events that weren't observed.",
          "Return your final answer as JSON with keys: scene, continuity, real_event, counterfactual_delta, continuation_beats, audio, camera, negative"
        ],
        "max_waves": 8
      },
      "input": [
        {"lane": "questions", "from": "chat_input"}
      ],
      "ui": {"position": {"x": 300, "y": 200}}
    },
    {
      "id": "llm_gmi_director",
      "provider": "llm_openai_api",
      "config": {
        "base_url": "https://api.gmi-serving.com/v1",
        "model": "deepseek-ai/DeepSeek-V4-Flash",
        "apikey": "${ROCKETRIDE_GMI_KEY}",
        "modelTotalTokens": 131072,
        "type": "llm"
      },
      "control": [
        {"classType": "llm", "from": "director_agent"}
      ],
      "ui": {"position": {"x": 300, "y": 0}}
    },
    {
      "id": "director_memory",
      "provider": "memory_internal",
      "config": {"type": "memory"},
      "control": [
        {"classType": "memory", "from": "director_agent"}
      ],
      "ui": {"position": {"x": 300, "y": 400}}
    },
    {
      "id": "tool_search_timeline",
      "provider": "tool_python",
      "config": {
        "type": "tool",
        "code": "import json\n\ndef run(query: str) -> str:\n    \"\"\"Search the match timeline for events matching the query.\"\"\"\n    # In production, this calls pgvector. For now, returns the timeline from memory.\n    return json.dumps({'result': 'Timeline search for: ' + query})\n",
        "description": "Search the match timeline for events, goals, shots, fouls, and other moments. Pass a natural language query.",
        "timeout": 30
      },
      "control": [
        {"classType": "tool", "from": "director_agent"}
      ],
      "ui": {"position": {"x": 500, "y": 100}}
    },
    {
      "id": "tool_compose_brief",
      "provider": "tool_python",
      "config": {
        "type": "tool",
        "code": "import json\n\ndef run(brief_json: str) -> str:\n    \"\"\"Validate and store the Veo generation brief.\"\"\"\n    brief = json.loads(brief_json)\n    required = ['scene', 'counterfactual_delta', 'continuation_beats']\n    missing = [k for k in required if k not in brief]\n    if missing:\n        return json.dumps({'error': f'Missing keys: {missing}'})\n    return json.dumps({'status': 'brief_ready', 'brief': brief})\n",
        "description": "Validate and finalize the Veo video generation brief. Pass the complete brief as a JSON string.",
        "timeout": 10
      },
      "control": [
        {"classType": "tool", "from": "director_agent"}
      ],
      "ui": {"position": {"x": 500, "y": 300}}
    },
    {
      "id": "response_output",
      "provider": "response_answers",
      "config": {"laneName": "answers"},
      "input": [
        {"lane": "answers", "from": "director_agent"}
      ],
      "ui": {"position": {"x": 600, "y": 200}}
    }
  ],
  "project_id": "whatif-director",
  "version": "1.0.0",
  "viewport": {"x": 0, "y": 0, "zoom": 1}
}
