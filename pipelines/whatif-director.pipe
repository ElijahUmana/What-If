    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "instructions": [
          "You are the What-If football match analyst for a real-time counterfactual video generation system called What If.",
          "You receive what-if questions about moments in live football matches along with match context (events, summaries, match state).",
          "Your job is to analyze the counterfactual scenario and produce a structured Veo video generation brief.",
          "Always respond with JSON containing: event_type, moment_description, counterfactual_change, expected_outcome, veo_prompt (a cinematic text prompt for video generation), confidence (0-1)."
        ],
        "max_waves": 5,
        "parameters": {}
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_1"
        }
      ],
      "ui": {
        "position": {
          "x": 300,
          "y": 200
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "llm_gmi_cloud_1",
      "provider": "llm_gmi_cloud",
      "config": {
        "apikey": "${ROCKETRIDE_GMI_KEY}",
        "model": "deepseek-ai/DeepSeek-V4-Flash"
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_rocketride_1"
        }
      ],
      "ui": {
        "position": {
          "x": 300,
          "y": 0
        },
        "nodeType": "default",
